# ============================================
# MULTIPLAYER SHOOTER — Configuración
# ============================================
# Copiar a .env y ajustar según entorno
# (No editar este archivo — crear .env a partir de él)

# --- Base de datos ---
# SQLite (desarrollo):
DB_URL=jdbc:sqlite:shooter.db
DB_USER=
DB_PASSWORD=

# PostgreSQL (producción):
# DB_URL=jdbc:postgresql://localhost:5432/shooter
# DB_USER=shooter_app
# DB_PASSWORD=secure_password

# --- Servidor WebSocket ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# --- JWT / Sesiones ---
JWT_SECRET=cambia_esto_en_produccion

# --- Game settings ---
TICK_RATE=20
MAX_PLAYERS_PER_ROOM=10
MIN_PLAYERS_TO_START=2
IDLE_THRESHOLD_MS=30000
IDLE_WARNING_DURATION_MS=10000

# --- Cliente ---
SERVER_URL=ws://localhost:8080
